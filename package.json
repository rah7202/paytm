{
  "name": "paytm",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:generate":"cd packages/db && npx prisma generate && cd ../..",
    "start-user-app": "cd ./apps/user-app && npm run start",
    
    "build":"npm run build:db && npm run build:user-app && npm run build:webhook",
    "build:db": "npm run build -w packages/db",
    "build:user-app": "npm run build -w apps/user-app",
    "build:webhook": "npm run build -w apps/bank-webhook",
    "start:webhhok": "node apps/bank-webhook/dist/index.js"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.7.2",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.7.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "recoil": "^0.7.7"
  }
}
